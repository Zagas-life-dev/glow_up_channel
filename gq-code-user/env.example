# Backend API (GlowUp main app). Required for QR app to fetch profile and update QR settings.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Public URL of this QR app. Used for the generated QR code link (what gets encoded in the QR image).
# Set this in production so scans open your deployed URL (e.g. https://qr.glowup.com).
NEXT_PUBLIC_APP_URL=http://localhost:3001
